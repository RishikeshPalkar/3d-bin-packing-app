###
# curl -X POST "http://localhost:8000/predict"
#-H "Content-Type: application/json"
#-d '{
#  "container": { "length": 10, "width": 10, "height": 10 },
#  "items": [
#    { "id": "item-1", "length": 3, "width": 3, "height": 3 },
#    { "id": "item-2", "length": 4, "width": 4, "height": 4 },
#    { "id": "item-3", "length": 2, "width": 2, "height": 2 }
#  ]
#}'
POST http://localhost:8000/predict
Content-Type: application/json

{
  "container": {
    "length": 10,
    "width": 10,
    "height": 10
  },
  "items": [
    {
      "id": "item-1",
      "length": 3,
      "width": 3,
      "height": 3
    },
    {
      "id": "item-2",
      "length": 4,
      "width": 4,
      "height": 4
    },
    {
      "id": "item-3",
      "length": 2,
      "width": 2,
      "height": 2
    }
  ]
}

