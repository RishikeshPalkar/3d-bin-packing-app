# curl -X POST "http://localhost:8123/api/v1/pack"
#-H "Content-Type: application/json"
#-d '{
#  "containerL": 10,
#  "containerW": 10,
#  "containerH": 10,
#  "items": [
#    { "name": "Box A", "length": 3, "width": 3, "height": 3 },
#    { "name": "Box B", "length": 4, "width": 4, "height": 4 }
#  ]
#}'
POST http://localhost:8123/api/v1/pack
Content-Type: application/json

{
  "containerL": 10,
  "containerW": 10,
  "containerH": 10,
  "items": [
    {
      "name": "Box A",
      "length": 3,
      "width": 3,
      "height": 3
    },
    {
      "name": "Box B",
      "length": 4,
      "width": 4,
      "height": 4
    }
  ]
}

